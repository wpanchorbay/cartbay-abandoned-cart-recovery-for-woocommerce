{
    "name": "wpanchorbay/cartbay-abandoned-cart-recovery-for-woocommerce",
    "description": "CartBay — Abandoned Cart Recovery for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "*",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "php-stubs/woocommerce-stubs": "^10.7.0",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "WPAnchorBay\\CartBay\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPAnchorBay\\CartBay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml cartbay-abandoned-cart-recovery-for-woocommerce.php app/ uninstall.php",
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "plugin-check": "wp plugin check cartbay-abandoned-cart-recovery-for-woocommerce",
        "test": "phpunit --configuration=phpunit.xml"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
