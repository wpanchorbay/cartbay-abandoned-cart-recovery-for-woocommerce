    },
    "scripts": {
        "start": "wp-scripts start --webpack-src-dir=src",
        "build": "wp-scripts build --webpack-src-dir=src",
        "dev": "node scripts/dev.js",
        "plugin-check": "wp plugin check cartbay-abandoned-cart-recovery-for-woocommerce",
