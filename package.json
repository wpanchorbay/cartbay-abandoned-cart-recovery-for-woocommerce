        "i18n:make-pot": "wp i18n make-pot . languages/cartbay-abandoned-cart-recovery-for-woocommerce.pot --exclude=vendor,node_modules,dist,src --domain=cartbay-abandoned-cart-recovery-for-woocommerce --headers='{\"Report-Msgid-Bugs-To\":\"https://wordpress.org/support/plugin/cartbay-abandoned-cart-recovery-for-woocommerce\"}'",
